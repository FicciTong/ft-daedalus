{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "instructions": [
    "docs/OPENCODE_HARNESS_OVERLAY.md"
  ],
  "default_agent": "main",
  "permission": {
    "todowrite": "allow",
    "lsp": "allow"
  },
  "agent": {
    "main": {
      "permission": {
        "task": {
          "*": "deny",
          "planner": "allow",
          "reviewer": "allow",
          "verifier": "allow"
        }
      }
    }
  },
  "snapshot": false,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8000
  },
  "watcher": {
    "ignore": [
      "**/.git/**",
      "**/.opencode/.state/**",
      "**/.venv/**",
      "**/node_modules/**",
      "**/__pycache__/**",
      "**/.pytest_cache/**",
      "**/.ruff_cache/**",
      "**/.mypy_cache/**",
      "**/.cache/**",
      "**/.next/**",
      "**/.turbo/**",
      "**/dist/**",
      "**/build/**",
      "**/coverage/**",
      "**/ops/**",
      "**/var/reports/organism/_state/**",
      "**/*.pyc"
    ]
  },
  "lsp": {
    "pyright": {
      "command": [
        "./.opencode/node_modules/.bin/pyright-langserver",
        "--stdio"
      ]
    },
    "typescript": {
      "command": [
        "./.opencode/node_modules/.bin/typescript-language-server",
        "--stdio"
      ]
    }
  }
}
