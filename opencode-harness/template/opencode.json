{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "instructions": [
    "docs/OPENCODE_HARNESS_OVERLAY.md"
  ],
  "default_agent": "harness-orchestrator",
  "snapshot": false,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8000
  },
  "watcher": {
    "ignore": [
      "**/.git/**",
      "**/.venv/**",
      "**/node_modules/**",
      "**/__pycache__/**",
      "**/.pytest_cache/**",
      "**/.ruff_cache/**",
      "**/.mypy_cache/**",
      "**/.cache/**",
      "**/.next/**",
      "**/.turbo/**",
      "**/dist/**",
      "**/build/**",
      "**/coverage/**",
      "**/*.pyc"
    ]
  }
}
