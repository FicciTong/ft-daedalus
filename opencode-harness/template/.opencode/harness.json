{
  "overlay_id": "ft-daedalus-opencode-harness",
  "overlay_version": "2026-04-09",
  "managed_paths": [
    ".opencode/.gitignore",
    ".opencode/harness.json",
    ".opencode/package.json",
    ".opencode/package-lock.json",
    ".opencode/agents/main.md",
    ".opencode/agents/planner.md",
    ".opencode/agents/reviewer.md",
    ".opencode/agents/verifier.md",
    ".opencode/commands/h-plan.md",
    ".opencode/commands/h-repair.md",
    ".opencode/commands/h-review.md",
    ".opencode/commands/h-verify.md",
    ".opencode/lib/run-harness.js",
    ".opencode/plugins/repo_harness.js",
    ".opencode/tools/affected_tests.js",
    ".opencode/tools/related_context.js",
    ".opencode/tools/repo_profile.js",
    ".opencode/tools/verify_changed.js",
    "docs/OPENCODE_HARNESS_OVERLAY.md",
    "scripts/opencode-local.sh",
    "scripts/repo_harness.py",
    "scripts/opencode_harness.py"
  ],
  "required_opencode_json": {
    "instructions": [
      "docs/OPENCODE_HARNESS_OVERLAY.md"
    ],
    "permission": {
      "todowrite": "allow",
      "lsp": "allow"
    },
    "agent": {
      "main": {
        "permission": {
          "task": {
            "*": "deny",
            "planner": "allow",
            "reviewer": "allow",
            "verifier": "allow"
          }
        }
      }
    },
    "lsp": {
      "pyright": {
        "command": [
          "./.opencode/node_modules/.bin/pyright-langserver",
          "--stdio"
        ]
      },
      "typescript": {
        "command": [
          "./.opencode/node_modules/.bin/typescript-language-server",
          "--stdio"
        ]
      }
    }
  },
  "required_opencode_package_json": {
    "type": "module",
    "dependencies": {
      "@opencode-ai/plugin": "1.4.0",
      "pyright": "^1.1.408",
      "typescript": "^6.0.2",
      "typescript-language-server": "^5.1.3"
    }
  },
  "required_opencode_gitignore_lines": [
    "node_modules/",
    "bun.lock",
    ".state/"
  ],
  "required_opencode_watcher_ignore": [
    "**/.git/**",
    "**/.venv/**",
    "**/node_modules/**",
    "**/__pycache__/**",
    "**/.pytest_cache/**",
    "**/.ruff_cache/**",
    "**/.mypy_cache/**",
    "**/.cache/**",
    "**/.next/**",
    "**/.turbo/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/*.pyc"
  ]
}
