[Unit]
Description=Daedalus WeChat Operator
After=network-online.target

[Service]
Type=notify
NotifyAccess=all
WorkingDirectory=%h/dev/ft-cosmos/ft-daedalus
EnvironmentFile=-%h/.config/daedalus-wechat.env
Environment=PATH=%h/.local/share/mise/installs/node/24.13.1/bin:%h/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=%h/dev/ft-cosmos/ft-daedalus/.venv/bin/daedalus-wechat run
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
