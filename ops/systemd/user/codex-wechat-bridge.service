[Unit]
Description=Codex WeChat Bridge
After=network-online.target

[Service]
Type=notify
NotifyAccess=all
WorkingDirectory=%h/dev/codex-wechat-bridge
EnvironmentFile=-%h/.config/codex-wechat-bridge.env
Environment=PATH=%h/.local/share/mise/installs/node/24.13.1/bin:%h/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=%h/dev/codex-wechat-bridge/.venv/bin/codex-wechat-bridge run
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
